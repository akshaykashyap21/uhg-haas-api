APP_ENV=development
NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

JWT_SECRET=local-dev-jwt-secret-change-me-32chars-min
JWT_ISSUER=azure-express-api
JWT_AUDIENCE=azure-express-clients
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local SQL Server — Windows Authentication
# Express edition: AZURE_SQL_HOST=localhost\SQLEXPRESS
AZURE_SQL_HOST=localhost
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=uhg
AZURE_SQL_WINDOWS_AUTH=true
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=true

TYPEORM_SYNC=false
TYPEORM_LOGGING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
LOG_LEVEL=debug
BCRYPT_SALT_ROUNDS=12
