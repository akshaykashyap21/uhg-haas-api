# JFrog Artifactory — set JFROG_* in shell/CI (see env/npm.jfrog.env)
# Virtual repo proxies npmjs + caches; local repo hosts @uhg-haas packages.

@uhg-haas:registry=https://${JFROG_NPM_REGISTRY_HOST}/artifactory/api/npm/${JFROG_NPM_LOCAL_REPO}/
//${JFROG_NPM_REGISTRY_HOST}/artifactory/api/npm/${JFROG_NPM_LOCAL_REPO}/:_authToken=${JFROG_NPM_TOKEN}

registry=https://${JFROG_NPM_REGISTRY_HOST}/artifactory/api/npm/${JFROG_NPM_VIRTUAL_REPO}/
//${JFROG_NPM_REGISTRY_HOST}/artifactory/api/npm/${JFROG_NPM_VIRTUAL_REPO}/:_authToken=${JFROG_NPM_TOKEN}

always-auth=true
engine-strict=true
save-exact=true
